rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admins can read/write all tasks; owners can manage their own; assignees can read theirs
    match /tasks/{taskId} {
      allow read, update, delete: if isAdmin();
      allow read: if resource.data.visibility == 'public'
                  || (request.auth != null && request.auth.uid == resource.data.uid)
                  || (request.auth != null && request.auth.uid == resource.data.assigneeId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // Admins can manage all categories; owners manage their own
    match /categories/{catId} {
      allow read, update, delete: if isAdmin();
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
    }

    // All signed-in users can read the user directory (for assign-to dropdown)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Admins collection: readable by all (needed for isAdmin() check), writable only by existing admins
    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
